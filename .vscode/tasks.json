{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build All",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--parallel"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "dependsOn": "CMake: Configure"
        },
        {
            "label": "Build: c++-decorator",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "c++-decorator",
                "--parallel"
            ],
            "group": "build",
            "problemMatcher": "$gcc",
            "dependsOn": "CMake: Configure"
        },
        {
            "label": "Build: c++-strong-type-test",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "c++-strong-type-test",
                "--parallel"
            ],
            "group": "build",
            "problemMatcher": "$gcc",
            "dependsOn": "CMake: Configure"
        },
        {
            "label": "Build: c++-limited-numeric-strong-type-test",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "c++-limited-numeric-strong-type-test",
                "--parallel"
            ],
            "group": "build",
            "problemMatcher": "$gcc",
            "dependsOn": "CMake: Configure"
        },
        {
            "label": "Build: c++-physical-unit-test",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "c++-physical-unit-test",
                "--parallel"
            ],
            "group": "build",
            "problemMatcher": "$gcc",
            "dependsOn": "CMake: Configure"
        },
        {
            "label": "Run: c++-decorator",
            "type": "shell",
            "command": "${workspaceFolder}/build/c++-decorator",
            "group": "test",
            "problemMatcher": [],
            "dependsOn": "Build: c++-decorator"
        },
        {
            "label": "Run: c++-strong-type-test",
            "type": "shell",
            "command": "${workspaceFolder}/build/c++-strong-type-test",
            "group": "test",
            "problemMatcher": [],
            "dependsOn": "Build: c++-strong-type-test"
        },
        {
            "label": "Run: c++-physical-unit-test",
            "type": "shell",
            "command": "${workspaceFolder}/build/c++-physical-unit-test",
            "group": "test",
            "problemMatcher": [],
            "dependsOn": "Build: c++-physical-unit-test"
        },
        {
            "label": "CMake: Clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "clean"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMake: Configure (compile_commands)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build: clang-tidy-plugin",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-shared",
                "-fPIC",
                "-fno-rtti",
                "-I/usr/lib/llvm21/include",
                "-std=c++17",
                "-DEXPERIMENTAL_KEY_INSTRUCTIONS",
                "-D__STDC_CONSTANT_MACROS",
                "-D__STDC_FORMAT_MACROS",
                "-D__STDC_LIMIT_MACROS",
                "-o",
                "${workspaceFolder}/clang-tidy-plugin/NoStandardTypesInInterfaceCheck.so",
                "${workspaceFolder}/clang-tidy-plugin/NoStandardTypesInInterfaceCheck.cpp"
            ],
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Clang-Tidy: All Projects",
            "type": "shell",
            "command": "find",
            "args": [
                "${workspaceFolder}/src",
                "${workspaceFolder}/libs",
                "-name",
                "*.cpp",
                "-exec",
                "clang-tidy",
                "--load=${workspaceFolder}/clang-tidy-plugin/NoStandardTypesInInterfaceCheck.so",
                "-p",
                "${workspaceFolder}/build",
                "{}",
                "+"
            ],
            "group": "test",
            "problemMatcher": "$gcc",
            "dependsOn": [
                "CMake: Configure (compile_commands)",
                "Build: clang-tidy-plugin"
            ]
        }
    ]
}